DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dev"

# ===========================================
# Parcha.cli Environment Variables
# ===========================================
# -------------------------------------------
# Server (Optional — defaults shown)
# -------------------------------------------
PORT="8000"
NODE_ENV="development"
BASE_URL="http://localhost:8000"

# -------------------------------------------
# Logger (Optional)
# -------------------------------------------
# Options: "error" | "info" | "debug"
# LOGGER_LEVEL="debug"

# -------------------------------------------
# Google OAuth (Optional)
# Leave empty to disable Google Sign-In
# -------------------------------------------
# GOOGLE_OAUTH_CLIENT_ID=""
# GOOGLE_OAUTH_CLIENT_SECRET=""
# GOOGLE_OAUTH_REDIRECT_URI="http://localhost:8000/api/authentication/google-callback"

# -------------------------------------------
# Frontend (Optional)
# -------------------------------------------
NEXT_PUBLIC_API_URL="http://localhost:8000/trpc"

# -------------------------------------------
# SMTP / Mail Service (Optional)
# -------------------------------------------
# SMTP_HOST="smtp.resend.com"
# SMTP_PORT="465"
# SMTP_USER="resend"
# SMTP_PASS=""
